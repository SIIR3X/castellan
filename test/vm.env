# Castellan test VM - shared, editable configuration for the test scripts.
#
# Point the e2e cycle / reset / setup at your own target by editing the values
# below. Sourced by test/e2e.sh and test/vm-reset.sh; the *_VM_NAME / *_CHECKPOINT
# values are also read by test/vm-reset-setup.ps1.
#
# Every value can still be overridden ad-hoc from the environment, which always
# wins over the default here (the ':=' assigns only when unset), e.g.:
#   CASTELLAN_HOST=10.0.0.5 make test
#
# NO secrets live here (IP, usernames, ports, names only) - the SSH key stays in
# test/secrets/. Keep it ASCII.

# --- target -----------------------------------------------------------------
: "${CASTELLAN_HOST:=192.168.1.43}"       # VM IP or hostname
: "${CASTELLAN_PORT:=22}"                 # SSH port after hardening (ssh_port)
: "${CASTELLAN_ADMIN:=castellan}"         # admin user Castellan creates
: "${CASTELLAN_INIT_USER:=lucas}"         # initial installer user (bootstrap)

# --- VM reset ---------------------------------------------------------------
: "${CASTELLAN_RESET_TIMEOUT:=300}"               # seconds to wait for SSH back
: "${CASTELLAN_VM_RESET_TASK:=CastellanVMReset}"  # Windows scheduled task name

# Hyper-V identity, used by test/vm-reset-setup.ps1 (one-time, elevated setup).
# Set CASTELLAN_VM_NAME to your VM's exact name (Get-VM lists them).
: "${CASTELLAN_VM_NAME:=}"
: "${CASTELLAN_CHECKPOINT:=clean-baseline}"
