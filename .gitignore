# Secrets - NEVER commit

# Ansible Vault password / passphrase
.vault_pass
*.vault_pass
.vault-password*
vault-password*

# SSH private keys (must never enter the repository)
id_rsa
id_ed25519
id_ecdsa
*.pem
*.key
files/private_keys/

# Possible plaintext secret files (just in case)
secrets.yml
secrets.yaml
*.secret

# Ansible
*.retry
.ansible/
fact_cache/

# Local test harness secrets (disposable container keys) - never commit
test/secrets/

# Generated reports (folder tracked via .gitkeep, contents ignored)
reports/*
!reports/.gitkeep

# Python (ansible)
__pycache__/
*.py[cod]
.venv/
venv/

# System / editors
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# Build output
/dist/
